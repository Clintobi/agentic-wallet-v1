{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dashboard/server.js"],
      "port": 3000,
      "env": {
        "WALLET_PASSPHRASE": "contest2025",
        "PORT": "3000"
      }
    },
    {
      "name": "agent-runner",
      "runtimeExecutable": "node",
      "runtimeArgs": ["src/agent.js", "--agents", "4"],
      "port": 3001,
      "env": {
        "WALLET_PASSPHRASE": "contest2025"
      }
    },
    {
      "name": "mcp-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["mcp/server.js"],
      "port": 3002,
      "env": {
        "WALLET_PASSPHRASE": "contest2025"
      }
    }
  ]
}
